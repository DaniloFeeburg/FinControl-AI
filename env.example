# FinControl-AI - Configuração de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# ============================================
# DATABASE
# ============================================
# String de conexão PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL=postgresql://user:password@localhost:5432/fincontrol

# ============================================
# SEGURANÇA
# ============================================
# Chave secreta para JWT (MÍNIMO 32 caracteres)
# Gerar com: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=your-secret-key-here-minimum-32-characters

# ============================================
# CORS
# ============================================
# Origens permitidas (separadas por vírgula)
# Desenvolvimento: http://localhost:3000,http://localhost:8080
# Produção: https://seu-dominio.com,https://www.seu-dominio.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# IA (OpenRouter)
# ============================================
# OpenRouter API Key (Obrigatório)
# Obter em: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Modelo principal (Opcional, default: mistralai/mistral-small-3.1-24b-instruct:free)
# Modelos free recomendados: mistralai/mistral-small-3.1-24b-instruct:free, qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

# Site URL para rankings OpenRouter (Opcional)
OPENROUTER_SITE_URL=

# App Name para rankings OpenRouter (Opcional)
OPENROUTER_APP_NAME=

# ============================================
# OUTROS
# ============================================
# Ambiente (development/production)
ENVIRONMENT=development

# Porta do servidor (padrão: 8080 no Cloud Run)
PORT=8080
